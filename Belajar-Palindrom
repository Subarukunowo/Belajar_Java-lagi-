class Solution {
    public String longestPalindrome(String s) {
      
        if (s == null || s.length() < 1) return "";
        
        int start = 0, end = 0;
        
        // Looping untuk mengunjungi setiap huruf sebagai titik pusat
        for (int i = 0; i < s.length(); i++) {
            // Kondisi 1: Pusat ganjil (contoh: "aba", pusatnya di 'b')
            int len1 = expandAroundCenter(s, i, i);
            
            // Kondisi 2: Pusat genap (contoh: "abba", pusatnya di antara 'b' dan 'b')
            int len2 = expandAroundCenter(s, i, i + 1);
            
            // Ambil panjang palindrom yang paling maksimal
            int len = Math.max(len1, len2);
            
            // Jika kita menemukan palindrom yang lebih panjang dari yang dicatat sebelumnya
            if (len > end - start) {
                // Update koordinat start dan end yang baru
                start = i - (len - 1) / 2;
                end = i + len / 2;
            }
        }
        
        // Potong string berdasarkan koordinat start dan end yang sudah didapat
        return s.substring(start, end + 1);
    }
    
    // Fungsi pembantu untuk meluas dari tengah
    private int expandAroundCenter(String s, int left, int right) {
        // Selama indeks tidak keluar batas DAN huruf di kiri-kanan kembar
        while (left >= 0 && right < s.length() && s.charAt(left) == s.charAt(right)) {
            left--;  // Mundur ke kiri
            right++; // Maju ke kanan
        }
        // Rumus matematika untuk menghitung panjang substring palindrom
        return right - left - 1;
    }
}
